# =============================================================================
# ReYMeN Agent — Environment Variables (Örnek)
# =============================================================================
# Kullanım: Bu dosyayı .env olarak kopyala, değerleri doldur.
#   cp .env.example .env
#
# ❌ .env DOSYASINI ASLA GIT'E COMMIT ETME!
# =============================================================================

# ── LLM Provider Key'leri ─────────────────────────────────────────────────
# En az BİR provider key'i zorunlu. Sıralı fallback zinciri çalışır.

# DeepSeek (birincil, önerilen) — en iyi fiyat/performans
DEEPSEEK_API_KEY=sk-buraya_keyinizi_yazin

# Xiaomi MiMo — en ucuz alternatif ($0.036/M token)
XIAOMI_API_KEY=sk-buraya_keyinizi_yazin

# Groq — ücretsiz tier mevcut (rate limited)
GROQ_API_KEY=gsk_buraya_keyinizi_yazin

# xAI (Grok) — backup
XAI_API_KEY=xai-buraya_keyinizi_yazin

# OpenAI — opsiyonel
OPENAI_API_KEY=sk-proj-buraya_keyinizi_yazin

# Anthropic — opsiyonel
ANTHROPIC_API_KEY=sk-ant-buraya_keyinizi_yazin

# OpenRouter — opsiyonel
OPENROUTER_API_KEY=sk-or-v1-buraya_keyinizi_yazin

# ── Provider Konfigürasyonu ──────────────────────────────────────────────
# Varsayılan model ve provider (boş bırakılırsa otomatik seçer)
ReYMeN_DEFAULT_PROVIDER=deepseek
ReYMeN_DEFAULT_MODEL=deepseek-chat
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# ─── Telegram Bot ────────────────────────────────────────────────────────
# Bot token'ları (BotFather'dan al)
TELEGRAM_BOT_TOKEN=buraya_bot_tokeni_yazin
# Chat ID (opsiyonel, bot mesaj atacağı hedef)
TELEGRAM_CHAT_ID=123456789

# ─── GitHub ──────────────────────────────────────────────────────────────
# GitHub Personal Access Token (repo işlemleri için)
GH_TOKEN=github_pat_buraya_yazin

# ─── Ajan Davranışı ──────────────────────────────────────────────────────
# Otomatik onay (true = soru sormadan işlem yap)
REYMEN_OTOMATIK_ONAY=true
# Maksimum adım sayısı
REYMEN_MAX_ADIM=15
# Dil (tr / en)
REYMEN_DIL=tr
# Alt ajan max adım
ALT_AJAN_MAX_ADIM=15
# Alt ajan zaman aşımı (saniye)
ALT_AJAN_ZAMAN_ASIMI=120
# YOLO modu (true = riskli işlemlere izin ver)
REYMEN_YOLO_MODE=false

# ─── Fal.ai (Image Generation) ───────────────────────────────────────────
FAL_KEY=buraya_fal_keyinizi_yazin

# ─── Perplexity (MCP Search) ─────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-buraya_keyinizi_yazin
PERPLEXITY_API_URL=https://api.perplexity.ai

# ─── X/Twitter API ───────────────────────────────────────────────────────
X_CONSUMER_KEY=buraya_yazin
X_CONSUMER_SECRET=buraya_yazin
X_ACCESS_TOKEN=buraya_yazin
X_ACCESS_TOKEN_SECRET=buraya_yazin
X_BEARER_TOKEN=buraya_yazin

# ─── PatentsView API ─────────────────────────────────────────────────────
PATENTSVIEW_API_KEY=buraya_yazin

# ─── LM Studio (Yerel Model) ─────────────────────────────────────────────
# Yerel LLM sunucusu (opsiyonel, varsayılan localhost:1234)
LM_STUDIO_URL=http://localhost:1234/v1

# ─── Derin Öğrenme (GPU) ────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0
TOKENIZERS_PARALLELISM=false
HF_HOME=
AUDIOCRAFT_CACHE_DIR=

# ─── İleri Seviye ────────────────────────────────────────────────────────
BROWSER_CDP_URL=http://localhost:9222
SETUP_COMPLETED=false
WANDB_MODE=offline
